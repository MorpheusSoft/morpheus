{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm"
  },
  "newProjectRoot": "projects",
  "projects": {
    "morpheus-wms": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:component": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "projects/morpheus-wms",
      "sourceRoot": "projects/morpheus-wms/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/morpheus-wms",
            "index": "projects/morpheus-wms/src/index.html",
            "browser": "projects/morpheus-wms/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/morpheus-wms/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/morpheus-wms/public"
              }
            ],
            "styles": [
              "projects/morpheus-wms/src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "morpheus-wms:build:production"
            },
            "development": {
              "buildTarget": "morpheus-wms:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "projects/morpheus-wms/tsconfig.spec.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/morpheus-wms/public"
              }
            ],
            "styles": [
              "projects/morpheus-wms/src/styles.css"
            ],
            "scripts": []
          }
        }
      }
    },
